# Copy this file:
#   cp deploy/env.example deploy/.env          # docker compose secrets
#   cp deploy/env.example apps/api/.env        # NestJS (edit APP_PUBLIC_URL etc.)
#
# Replace CHANGE_ME_* and YOUR_VM_PUBLIC_IP before starting.

# --- Docker Compose (Postgres + MinIO) ---
POSTGRES_USER=splitsaathi
POSTGRES_PASSWORD=splitsaathi@123
POSTGRES_DB=splitsaathi
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=splitsaathi@123
S3_BUCKET=splitsaathi

# --- NestJS API ---
NODE_ENV=production
HOST=127.0.0.1
PORT=3000

# Must match compose credentials (localhost because Nest runs on the host, not in Docker)
# Note: @ in the password must be URL-encoded as %40 inside DATABASE_URL
DATABASE_URL=postgres://splitsaathi:splitsaathi%40123@127.0.0.1:5432/splitsaathi

JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET_AT_LEAST_16_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_AT_LEAST_16_CHARS

# Public URL the mobile app / invite links will use (no trailing slash)
APP_PUBLIC_URL=http://YOUR_VM_PUBLIC_IP
MOBILE_API_URL=http://YOUR_VM_PUBLIC_IP

# Early VM smoke-test: allow OTP/email/push/payment "dev|manual" drivers.
# Set to false and wire real providers before real user data.
ALLOW_INSECURE_DEV_PROVIDERS=true
OTP_PROVIDER_DRIVER=dev
OTP_DEV_CODE=123456
EMAIL_PROVIDER_DRIVER=dev
EMAIL_DEV_CODE=123456
NOTIFICATION_PROVIDER_DRIVER=dev
PAYMENT_GATEWAY_DRIVER=manual
UPI_INTENT_PROVIDER_DRIVER=dev
OCR_PROVIDER_DRIVER=noop
BANK_IMPORT_PROVIDER_DRIVER=csv
FX_PROVIDER_DRIVER=static
METRICS_ENABLED=true

# Object storage via MinIO (S3-compatible) on localhost — include port in endpoint
OBJECT_STORAGE_DRIVER=s3
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=splitsaathi
S3_ACCESS_KEY_ID=admin
S3_SECRET_ACCESS_KEY=splitsaathi@123
S3_USE_SSL=false
