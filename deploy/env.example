# Copy this file:
#   cp deploy/env.example deploy/.env                 # compose secrets
#   cp deploy/env.example deploy/api.docker.env       # then edit for Docker API
#
# For Docker API: HOST=0.0.0.0, DATABASE_URL host = postgres, S3_ENDPOINT = http://minio:9000

# --- Docker Compose (Postgres + MinIO) ---
POSTGRES_USER=splitsaathi
POSTGRES_PASSWORD=splitsaathi@123
POSTGRES_DB=splitsaathi
POSTGRES_HOST_PORT=5433
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=splitsaathi@123
S3_BUCKET=splitsaathi

# --- NestJS API (use in deploy/api.docker.env) ---
NODE_ENV=production
HOST=0.0.0.0
PORT=3000

# Inside Docker network — service name "postgres", port 5432
DATABASE_URL=postgres://splitsaathi:splitsaathi%40123@postgres:5432/splitsaathi

JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET_AT_LEAST_16_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_AT_LEAST_16_CHARS

APP_PUBLIC_URL=https://api.thesplitsaathi.com
MOBILE_API_URL=https://api.thesplitsaathi.com

# Android App Links (SHA-256 of APK signing cert). Comma-separated if multiple.
# Current assembleRelease uses android/app/debug.keystore — leave default in code or set:
# ANDROID_APP_LINK_SHA256=FA:C6:17:45:DC:09:03:78:6F:B9:ED:E6:2A:96:2B:39:9F:73:48:F0:BB:6F:89:9B:83:32:66:75:91:03:3B:9C

ALLOW_INSECURE_DEV_PROVIDERS=true
OTP_PROVIDER_DRIVER=dev
OTP_DEV_CODE=123456
EMAIL_PROVIDER_DRIVER=dev
EMAIL_DEV_CODE=123456

NOTIFICATION_PROVIDER_DRIVER=fcm
# FCM — place file at deploy/secrets/fcm-service-account.json (mounted by docker-compose)
FCM_PROJECT_ID=splitsaathi-ebe8a
FCM_SERVICE_ACCOUNT_PATH=/run/secrets/fcm-service-account.json

PAYMENT_GATEWAY_DRIVER=cashfree
CASHFREE_APP_ID=TEST_APP_ID
CASHFREE_SECRET_KEY=TEST_SECRET_KEY
CASHFREE_ENV=sandbox
UPI_INTENT_PROVIDER_DRIVER=dev
OCR_PROVIDER_DRIVER=noop
BANK_IMPORT_PROVIDER_DRIVER=csv
FX_PROVIDER_DRIVER=static
METRICS_ENABLED=true

# Shared secret for external cron → POST /v1/jobs/* (header: x-cron-secret)
CRON_SECRET=CHANGE_ME_CRON_SECRET_AT_LEAST_16_CHARS

GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com

OBJECT_STORAGE_DRIVER=s3
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=splitsaathi
S3_ACCESS_KEY_ID=admin
S3_SECRET_ACCESS_KEY=splitsaathi@123
S3_USE_SSL=false

# --- Optional integrations ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_VERIFY_SERVICE_SID=
# OTP_PROVIDER_DRIVER=twilio_verify
# RESEND_API_KEY=
# EMAIL_FROM=SplitSaathi <noreply@yourdomain.com>
# EMAIL_PROVIDER_DRIVER=resend
