{
  "name": "splitsaathi",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build -ws --if-present",
    "lint": "npm run lint -ws --if-present",
    "test": "npm run test -ws --if-present",
    "test:unit": "npm run test:unit -ws --if-present",
    "test:integration": "npm run test:integration -w @splitsaathi/api",
    "migration:run": "npm run migration:run -w @splitsaathi/db",
    "setup:db": "powershell -ExecutionPolicy Bypass -File scripts/setup-local-db.ps1",
    "dev:api": "npm run start:dev -w @splitsaathi/api",
    "dev:mobile": "npm run start -w @splitsaathi/mobile",
    "deploy:build": "bash deploy/build.sh",
    "deploy:start": "bash deploy/start.sh"
  },
  "devDependencies": {
    "@babel/helper-optimise-call-expression": "^7.29.7",
    "@babel/plugin-syntax-decorators": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@types/bcrypt": "^6.0.0",
    "@expo/cli": "^0.22.28",
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "embedded-postgres": "^18.4.0-beta.17",
    "jest": "^29.7.0",
    "metro": "^0.81.5",
    "metro-cache": "^0.81.5",
    "metro-config": "^0.81.5",
    "metro-core": "^0.81.5",
    "metro-resolver": "^0.81.5",
    "metro-runtime": "^0.81.5",
    "metro-source-map": "^0.81.5",
    "metro-symbolicate": "^0.81.5",
    "metro-transform-worker": "^0.81.5",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  },
  "overrides": {},
  "dependencies": {
    "bcrypt": "^6.0.0"
  }
}
