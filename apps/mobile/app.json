{
  "expo": {
    "name": "SplitSaathi",
    "slug": "splitsaathi",
    "scheme": "splitsaathi",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "in.splitsaathi.mobile"
    },
    "android": {
      "package": "in.splitsaathi.mobile",
      "usesCleartextTraffic": true
    },
    "extra": {
      "router": {
        "origin": "http://65.20.81.44"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-sqlite",
      [
        "expo-contacts",
        {
          "contactsPermission": "Allow SplitSaathi to find friends who already use the app."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow SplitSaathi to scan invite QR codes."
        }
      ],
      "expo-notifications",
      "expo-asset",
      "expo-font",
      "@react-native-community/datetimepicker",
      "expo-web-browser"
    ]
  }
}
