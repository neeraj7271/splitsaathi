{
  "expo": {
    "name": "SplitSaathi",
    "slug": "splitsaathi",
    "scheme": "splitsaathi",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0E14"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "in.splitsaathi.mobile",
      "icon": "./assets/icon.png"
    },
    "android": {
      "package": "in.splitsaathi.mobile",
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      }
    },
    "extra": {
      "router": {
        "origin": "http://65.20.81.44"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-sqlite",
      [
        "expo-contacts",
        {
          "contactsPermission": "Allow SplitSaathi to find friends who already use the app."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow SplitSaathi to scan invite QR codes."
        }
      ],
      "expo-notifications",
      "expo-local-authentication",
      "expo-asset",
      "expo-font",
      "@react-native-community/datetimepicker",
      "expo-web-browser",
      "@react-native-google-signin/google-signin"
    ]
  }
}
