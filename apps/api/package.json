{
  "name": "@splitsaathi/api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "test": "jest",
    "test:unit": "jest --testPathIgnorePatterns=e2e-spec",
    "test:integration": "jest --testMatch **/*.e2e-spec.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "migration:run": "npm run migration:run -w @splitsaathi/db"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^8.1.0",
    "@nestjs/typeorm": "^10.0.2",
    "@splitsaathi/config": "0.1.0",
    "@splitsaathi/contracts": "0.1.0",
    "@splitsaathi/db": "0.1.0",
    "@splitsaathi/domain": "0.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "minio": "^8.0.7",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "tesseract.js": "^7.0.0",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@nestjs/testing": "^10.4.15",
    "@types/express": "^4.17.21",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "typeorm-ts-node-commonjs": "^0.3.20"
  }
}
