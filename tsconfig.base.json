{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "declaration": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@splitsaathi/config": ["packages/config/src"],
      "@splitsaathi/contracts": ["packages/contracts/src"],
      "@splitsaathi/db": ["packages/db/src"],
      "@splitsaathi/domain": ["packages/domain/src"],
      "@splitsaathi/testing": ["packages/testing/src"]
    }
  }
}
